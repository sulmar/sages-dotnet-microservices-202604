{

  "ReverseProxy": {

    "Routes": {

      "identity-provider-route": {
        "ClusterId": "identity-provider-cluster",
        "Match": {
          "Path": "/api/login/{**catch-all}"
        }
      },

      "dashboard-route": {

        "ClusterId": "dashboard-cluster",
        "Match": {
          "Path": "/signalr/{**catch-all}"
        }
      },

      "blazor-app-route": {
        "ClusterId": "blazor-app-cluster",
        "Match": {
          "Path": "/{**catch-all}"
        }

      },

      "product-catalog-route": {
        "ClusterId": "product-catalog-cluster",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      },

      "shopping-cart-route": {
        "ClusterId": "shopping-cart-cluster",
        "Match": {
          "Path": "/api/cart/{**catch-all}"
        }
      },

      "ordering-route": {
        "ClusterId": "ordering-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      }
    },

    "Clusters": {

      "identity-provider-cluster": {
        "Destinations": {
          "identity-provider-destination1": {
            "Address": "https://identity-provider"
          }
        }
      },

      "dashboard-cluster": {
        "Destinations": {
          "dashboard-destination1": {
            "Address": "https://dashboard"
          }
        }

      },

      "blazor-app-cluster": {
        "Destinations": {
          "blazor-app-destination1": {
            "Address": "https://blazor-app"
          }
        }
      },

      "product-catalog-cluster": {
        "Destinations": {
          "product-catalog-destination1": {
            "Address": "https://product-catalog"
          }
        }
      },
      "shopping-cart-cluster": {
        "Destinations": {
          "shopping-cart-destination1": {
            "Address": "https://shopping-cart"
          }
        }
      },

      "ordering-cluster": {
        "Destinations": {
          "ordering-destination1": {
            "Address": "https://ordering"
          }
        }
      }

    }
  }
}