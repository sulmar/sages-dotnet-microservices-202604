@page "/stock"
@using Microsoft.AspNetCore.SignalR.Client
@using BlazorApp.Model

<PageTitle>Stock</PageTitle>

<section class="py-5">
    <div class="container px-4 px-lg-5 mt-5">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-10 col-xl-8">
                <h2 class="h3 mb-3">Stock</h2>
                <p class="text-muted mb-4">
                    <span class="fw-semibold text-body">Status:</span>
                    @_status
                </p>

                <div class="card shadow-sm border-0">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th scope="col">Product</th>
                                        <th scope="col" class="text-end">Quantity</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (_stock.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="2" class="text-center text-muted py-4 border-0">No stock data yet.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var item in _stock.OrderBy(static x => x.Key))
                                        {
                                            <tr>
                                                <td>@item.Key</td>
                                                <td class="text-end font-monospace">@item.Value</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {

    private HubConnection _connection = default!;
    private string _status = "Connecting to SignalR hub...";
    private Dictionary<int, int> _stock = new();

    protected override async Task OnInitializedAsync()
    {
        _connection = new HubConnectionBuilder()
            .WithUrl("https://localhost:7000/signalr/stock")
            .WithAutomaticReconnect()
            .Build();

        _connection.On<StockUpdateDto>("StockUpdated", update =>
        {
            _stock[update.ProductId] = update.Quantity;

            InvokeAsync(StateHasChanged);
        });

        await _connection.StartAsync();

        _status = "Connected to SignalR hub.";
    }

}
