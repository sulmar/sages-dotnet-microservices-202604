{

  "ReverseProxy": {

    "Routes": {

      "blazor-app-route": {
        "ClusterId": "blazor-app-cluster",
        "Match": {
          "Path": "/{**catch-all}"
        }

      },

      "product-catalog-route": {
        "ClusterId": "product-catalog-cluster",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      },

      "shopping-cart-route": {
        "ClusterId": "shopping-cart-cluster",
        "Match": {
          "Path": "/api/cart/{**catch-all}"
        }
      }
    },

    "Clusters": {

      "blazor-app-cluster": {
        "Destinations": {
          "blazor-app-destination1": {
            "Address": "https://blazor-app"
          }
        }
      },

      "product-catalog-cluster": {
        "Destinations": {
          "product-catalog-destination1": {
            "Address": "https://product-catalog"
          }
        }
      },
      "shopping-cart-cluster": {
        "Destinations": {
          "shopping-cart-destination1": {
            "Address": "https://shopping-cart"
          }
        }
      }
    }

  }
}