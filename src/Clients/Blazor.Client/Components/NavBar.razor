@using BlazorApp.Model
@using BlazorApp.Services
@inject ICartService Cart
@inject IProductService ProductService
@implements IDisposable

<!-- Navigation-->
<nav class="navbar navbar-expand-lg navbar-light bg-light">
    <div class="container px-4 px-lg-5">
        <a class="navbar-brand" href="#!">Start Bootstrap</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                <li class="nav-item">
                    <a class="nav-link active" aria-current="page" href="#!">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/dashboard">Dashboard</a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" id="navbarDropdown" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Shop</a>
                    <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                        <li>
                            <a class="dropdown-item" href="#!">All Products</a>
                        </li>
                        <li>
                            <hr class="dropdown-divider" />
                        </li>
                        <li>
                            <a class="dropdown-item" href="#!">Popular Items</a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="#!">New Arrivals</a>
                        </li>
                    </ul>
                </li>
            </ul>

            <LoginComponent />

            <div class="d-flex ms-lg-2">
                <div class="dropdown">
                    <button class="btn btn-outline-dark dropdown-toggle" type="button"
                            aria-expanded="@cartDropdownOpen"
                            @onclick="ToggleCartDropdown">
                        <i class="bi-cart-fill me-1"></i>
                        Koszyk
                        <span class="badge bg-dark text-white ms-1 rounded-pill">@TotalQuantity</span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end p-3 shadow @(cartDropdownOpen ? "show" : "")"
                         style="min-width: 320px; max-height: 420px; overflow-y: auto;">
                        @if (cartItems is null || catalog is null)
                        {
                            <span class="text-muted small">Ładowanie...</span>
                        }
                        else if (cartItems.Count == 0)
                        {
                            <span class="text-muted small">Koszyk jest pusty.</span>
                        }
                        else
                        {
                            <div class="small text-uppercase text-muted mb-2">Podgląd koszyka</div>
                            @foreach (var line in cartItems)
                            {
                                var product = ResolveProduct(line.ProductId);
                                var unit = product?.DiscountedPrice ?? 0m;
                                var lineTotal = unit * line.Quantity;
                                <div class="d-flex justify-content-between align-items-start gap-2 py-2 border-bottom">
                                    <div>
                                        <div class="fw-semibold">@(product?.Name ?? $"Produkt #{line.ProductId}")</div>
                                        <div class="text-muted">@line.Quantity × @unit.ToString("C")</div>
                                    </div>
                                    <div class="text-nowrap fw-semibold">@lineTotal.ToString("C")</div>
                                </div>
                            }
                            <div class="d-flex justify-content-between align-items-center pt-3 mt-1">
                                <span class="fw-bold">Razem</span>
                                <span class="fw-bold">@CartTotal.ToString("C")</span>
                            </div>
                            <button type="button" class="btn btn-dark w-100 mt-3" @onclick="CheckoutAsync" disabled="@checkoutBusy">
                                @(checkoutBusy ? "Przetwarzanie..." : "Złóż zamówienie")
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</nav>

@code {
    private List<CartItem>? cartItems;
    private List<Product>? catalog;
    private bool checkoutBusy;
    private bool cartDropdownOpen;

    private int TotalQuantity => cartItems?.Sum(x => x.Quantity) ?? 0;

    private decimal CartTotal =>
        cartItems?.Sum(line =>
        {
            var p = ResolveProduct(line.ProductId);
            var unit = p?.DiscountedPrice ?? 0m;
            return unit * line.Quantity;
        }) ?? 0m;

    protected override async Task OnInitializedAsync()
    {
        Cart.CartChanged += OnCartChanged;
        catalog = await ProductService.GetAllAsync();
        await RefreshCartAsync();
    }

    private void ToggleCartDropdown()
    {
        cartDropdownOpen = !cartDropdownOpen;
    }

    private void OnCartChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await RefreshCartAsync();
            StateHasChanged();
        });
    }

    private async Task RefreshCartAsync()
    {
        cartItems = await Cart.GetCartItemsAsync() ?? [];
    }

    private Product? ResolveProduct(int productId) =>
        catalog?.FirstOrDefault(p => p.Id == productId);

    private async Task CheckoutAsync()
    {
        if (checkoutBusy || TotalQuantity == 0)
            return;

        checkoutBusy = true;
        try
        {
            await Cart.CheckoutAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Checkout error: {ex.Message}");
        }
        finally
        {
            checkoutBusy = false;
        }
    }

    public void Dispose()
    {
        Cart.CartChanged -= OnCartChanged;
    }
}
